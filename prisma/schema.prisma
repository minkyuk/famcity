generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String              @id @default(cuid())
  name            String?
  email           String?             @unique
  emailVerified   DateTime?
  image           String?
  bio             String?
  credits         Int                 @default(100)
  accounts        Account[]
  aiConversations AiConversation[]
  chatMessages    ChatMessage[]
  comments        Comment[]
  creditTxns      CreditTransaction[]
  sentDMs         DirectMessage[]     @relation("DMSent")
  receivedDMs     DirectMessage[]     @relation("DMReceived")
  createdEvents   Event[]
  eventRsvps      EventRSVP[]
  presence        OnlinePresence?
  posts           Post[]
  sessions        Session[]
  spaces          SpaceMember[]
  commentLikes    CommentLike[]
  payments        Payment[]
  patreonAccount  PatreonAccount?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Space {
  id              String           @id @default(cuid())
  name            String
  description     String?
  inviteCode          String           @unique
  inviteCodeExpiresAt DateTime?
  createdAt           DateTime         @default(now())
  excludeFromAll  Boolean          @default(false)
  isSystem        Boolean          @default(false)
  purpose         String?
  chatChannels    ChatChannel[]
  events          Event[]
  onlinePresences OnlinePresence[]
  posts           Post[]
  spaceAgents     SpaceAgent[]
  members         SpaceMember[]
}

model SpaceAgent {
  id          String   @id @default(cuid())
  spaceId     String
  name        String
  personality String
  slug        String   @unique
  createdAt   DateTime @default(now())
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, name])
}

model SpaceMember {
  id       String    @id @default(cuid())
  userId   String
  spaceId  String
  role     SpaceRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  space    Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
}

model Post {
  id          String        @id @default(cuid())
  authorName  String
  content     String?
  type        PostType
  mediaUrl    String?
  createdAt   DateTime      @default(now())
  authorImage String?
  userId      String?
  spaceId     String?
  isPrivate   Boolean       @default(false)
  summary     String?
  metadata    Json?
  comments    Comment[]
  space       Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id])
  hashtags    PostHashtag[]
  media       PostMedia[]
  reactions   Reaction[]
}

model PostMedia {
  id     String @id @default(cuid())
  postId String
  url    String
  order  Int    @default(0)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Hashtag {
  id    String        @id @default(cuid())
  tag   String        @unique
  posts PostHashtag[]
}

model PostHashtag {
  postId    String
  hashtagId String
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String
  emoji     String
  name      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, emoji, name])
}

model Comment {
  id          String        @id @default(cuid())
  postId      String
  authorName  String
  body        String
  createdAt   DateTime      @default(now())
  authorImage String?
  userId      String?
  parentId    String?
  summary     String?
  likes       Int           @default(0)
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]     @relation("CommentReplies")
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id])
  commentLikes CommentLike[]
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  name      String
  createdAt DateTime @default(now())
}

model ChatChannel {
  id           String           @id @default(cuid())
  name         String
  description  String?
  isGlobal     Boolean          @default(false)
  passwordHash String?
  createdById  String?
  createdAt    DateTime         @default(now())
  spaceId      String?
  space        Space?           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  presence     OnlinePresence[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  channelId String
  userId    String
  userName  String
  userImage String?
  content   String
  createdAt DateTime    @default(now())
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OnlinePresence {
  userId    String       @id
  name      String
  image     String?
  channelId String?
  lastSeen  DateTime     @default(now())
  spaceId   String?
  channel   ChatChannel? @relation(fields: [channelId], references: [id])
  space     Space?       @relation(fields: [spaceId], references: [id])
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DirectMessage {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  content    String
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)
  fromUser   User     @relation("DMSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("DMReceived", fields: [toUserId], references: [id], onDelete: Cascade)
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  location    String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean     @default(false)
  spaceId     String?
  createdById String
  createdAt   DateTime    @default(now())
  createdBy   User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  space       Space?      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  rsvps       EventRSVP[]
}

model EventRSVP {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RSVPStatus
  createdAt DateTime   @default(now())
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  spaceId   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PatreonAccount {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  patreonUserId  String    @unique
  accessToken    String
  refreshToken   String?
  tierCents      Int       @default(0)  // currently_entitled_amount_cents
  patronStatus   String    @default("active_patron")
  lastCreditedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credits    Int
  usdCents   Int
  provider   String   // "paypal" | "btc"
  externalId String   @unique
  status     String   @default("pending") // pending | completed | failed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model AiConversation {
  id        String                  @id @default(cuid())
  userId    String
  title     String
  model     String                  @default("claude-sonnet-4-6")
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiConversationMessage[]
}

model AiConversationMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AgentMemory {
  agentSlug     String   @id
  beliefs       Json
  updatedAt     DateTime @updatedAt
  relationships Json?
  description   String?
}

enum SpaceRole {
  OWNER
  MEMBER
}

enum PostType {
  TEXT
  IMAGE
  YOUTUBE
  AUDIO
  VIDEO
  PDF
}

enum RSVPStatus {
  YES
  NO
  MAYBE
}
